      "position": [1200, 300],
      "credentials": [],
      "inputs": [{"type": "main"}],
      "outputs": [{"type": "main"}],
      "nativeCredentials": []
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "sourceLanguage": "javaScript",
        "javascriptCode": "const items = $input.all();\n\n// If an upstream node already produced { trends: [...] }, keep it as-is\nif (items.length === 1 && items[0].json && Array.isArray(items[0].json.trends)) {\n  return { json: items[0].json };\n}\n\n// Otherwise collect individual trend items into the payload expected by the backend\nconst trends = items\n  .map((item) => item.json)\n  .filter((trend) => trend && trend.topic);\n\nreturn {\n  json: {\n    trends,\n    count: trends.length,\n    timestamp: new Date().toISOString(),\n  },\n};"
      },
      "id": "Batch",
      "name": "Batch Trends",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1450, 300],
      "credentials": [],
      "inputs": [{"type": "main"}],
      "outputs": [{"type": "main"}],
