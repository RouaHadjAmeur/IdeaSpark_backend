# ─── n8n Webhook URLs ─────────────────────────────────────────────────────────
# These URLs come from n8n after you activate each workflow.
# Format: http://localhost:5678/webhook/{path}

N8N_WEBHOOK_USER_REGISTERED=http://localhost:5678/webhook/user-registered
N8N_WEBHOOK_USER_ACTIVATED=http://localhost:5678/webhook/user-registered
N8N_WEBHOOK_SLOGAN_SAVED=http://localhost:5678/webhook/slogan-saved
N8N_WEBHOOK_VIDEO_APPROVED=http://localhost:5678/webhook/video-approved
N8N_WEBHOOK_CREDITS_PURCHASED=http://localhost:5678/webhook/credits-purchased

# ─── Security ──────────────────────────────────────────────────────────────────
# This secret is checked when n8n calls your NestJS endpoints (e.g. /trends/update)
# Must match the ?secret= query param in n8n workflow nodes
N8N_SECRET=ideaspark_n8n_secret_change_me_in_prod

# ─── n8n Variable (set this inside n8n UI → Settings → Variables) ─────────────
# Name:  N8N_NESTJS_SECRET
# Value: same as N8N_SECRET above
# Used in workflow 02 node "POST to NestJS /trends/update"
